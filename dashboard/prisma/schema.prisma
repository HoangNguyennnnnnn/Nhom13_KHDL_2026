generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id              String  @id
  brand           String?
  clusterId       Int?
  clusterName     String?
  discountedPrice Float?
  avgStarRating   Float?
}

model Customer {
  id               String @id
  email            String?
  rfmSegment       Int?
  churnProbability Float
}

model ForecastRun {
  id              Int      @id @default(autoincrement())
  productId       String
  predictedDate   DateTime
  predictedVolume Float
  trend           String
  createdAt       DateTime @default(now())
}
